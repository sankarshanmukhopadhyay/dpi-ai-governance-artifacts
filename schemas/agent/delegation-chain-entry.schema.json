{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/agent/delegation-chain-entry.schema.json",
  "title": "Delegation Chain Entry",
  "description": "A minimal provenance record for delegated authority across humans, agents, and systems. Enables post-incident reconstruction and accountability assignment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chain_id",
    "recorded_at",
    "steps"
  ],
  "properties": {
    "chain_id": {
      "type": "string"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actor_type",
          "actor_id",
          "action",
          "scope"
        ],
        "properties": {
          "actor_type": {
            "type": "string",
            "enum": [
              "human",
              "org",
              "agent",
              "service",
              "platform"
            ]
          },
          "actor_id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "description": "The delegated action or authority (e.g., 'submit_claim', 'approve_benefit', 'call_payment_api')."
          },
          "scope": {
            "type": "string"
          },
          "delegation_ref": {
            "type": "string",
            "description": "Reference to signed delegation or mandate artifact."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}