{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "minimum-audit-trail.schema.json",
  "title": "Minimum Audit Trail",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "system",
    "events"
  ],
  "properties": {
    "version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "system": {
      "type": "string",
      "minLength": 3
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "timestamp",
          "event_type",
          "actor",
          "artifact_ref"
        ],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "event_type": {
            "type": "string",
            "minLength": 3
          },
          "actor": {
            "type": "string",
            "minLength": 2
          },
          "artifact_ref": {
            "type": "string",
            "minLength": 3
          },
          "outcome": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
