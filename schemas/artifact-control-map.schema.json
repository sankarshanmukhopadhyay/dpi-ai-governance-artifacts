{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact-control-map.schema.json",
  "title": "Artifact to Control Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_id",
    "control_mappings"
  ],
  "properties": {
    "version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "artifact_id": {
      "type": "string",
      "minLength": 3
    },
    "artifact_type": {
      "type": "string"
    },
    "control_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "coverage",
          "evidence"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^DPI-AI-CTRL-"
          },
          "coverage": {
            "type": "string",
            "enum": [
              "full",
              "partial",
              "informative"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
