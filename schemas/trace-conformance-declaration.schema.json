{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trace-conformance-declaration.schema.json",
  "title": "TRACE Conformance Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_bundle",
    "trace_method_version",
    "declaration",
    "evidence"
  ],
  "properties": {
    "version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "artifact_bundle": {
      "type": "string",
      "minLength": 3
    },
    "trace_method_version": {
      "type": "string",
      "minLength": 1
    },
    "declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "scope"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "declared",
            "tested",
            "independently_reviewed"
          ]
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    }
  }
}
